<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/taskCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/theme_surface"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="#1AFFFFFF"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Time Badge -->
        <LinearLayout
            android:id="@+id/timeBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#1A00E5FF"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvTaskTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:00 AM"
                android:textColor="@color/secondary_color"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTaskDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • 60m"
                android:textColor="@color/secondary_color"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Adjusted Label -->
        <TextView
            android:id="@+id/tvAdjusted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="#1AFFD166"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="FlexPlan Adjusted"
            android:textColor="@color/theme_accent"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/timeBadge"
            app:layout_constraintStart_toEndOf="@id/timeBadge"
            app:layout_constraintTop_toTopOf="@id/timeBadge" />

        <TextView
            android:id="@+id/tvTaskTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:text="Task Title"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/ivStatusIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/timeBadge" />

        <TextView
            android:id="@+id/tvTaskDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Description goes here..."
            android:textColor="@color/text_gray"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="@id/tvTaskTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTaskTitle" />

        <ImageView
            android:id="@+id/ivStatusIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_checkbox_unselected"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="Status" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
